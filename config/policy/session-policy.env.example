# Copy to /etc/htdm/session-policy.env (or equivalent) in deployment.

# User that is allowed to run unauthenticated game mode.
HTDM_GAMING_USER=gaming

# Auth marker expected by desktop launcher wrapper.
# Greeter/controller should set this only after successful PAM auth.
HTDM_AUTH_MARKER_ENV=HTDM_DESKTOP_AUTH_OK

# Allowed desktop session IDs and their launch commands.
HTDM_DESKTOP_SESSION_GNOME="gnome:gnome-session"
HTDM_DESKTOP_SESSION_KDE="kde:startplasma-wayland"
HTDM_ALLOWED_DESKTOP_USERS=""

# Allowed game session command.
HTDM_GAME_SESSION="gamescope:gamescope-session"

# Theme and resume/session-switch wiring.
HTDM_THEME_PRESET_FILE=/etc/htdm/themes/presets.json
HTDM_CURRENT_THEME_FILE=/var/lib/htdm/theme/current-theme.json
HTDM_RESUME_STATE_FILE=/run/htdm/resume/state.env
HTDM_RESUME_ACTION_FILE=/run/htdm/resume/action

# Basic desktop configurator policy values.
HTDM_AUTO_LAUNCH_MODE=off
HTDM_AUTO_LAUNCH_SESSION=
HTDM_DEFAULT_DESKTOP_SESSION=gnome
HTDM_RESUME_DEFAULT_ACTION=return-to-game
